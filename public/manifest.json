{
  "manifest_version": 3,
  "name": "Qdrant Cluster Dashboard",
  "description": "Monitor and manage your Qdrant clusters directly from Chrome",
  "version": "0.1.0",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Qdrant Clusters"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
